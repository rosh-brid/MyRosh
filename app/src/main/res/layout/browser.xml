<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     android:layout_height="match_parent"
     android:layout_width="match_parent"
     android:background="@color/bg"
     android:id="@+id/pusat">

    <LinearLayout
         android:layout_height="match_parent"
         android:layout_width="match_parent"
         android:orientation="vertical">

        <LinearLayout
             android:layout_height="40dp"
             android:layout_width="match_parent"
             android:gravity="center_vertical"
             android:background="@color/biru">

            <ImageView
                 android:layout_height="30dp"
                 android:layout_width="30dp"
                 android:layout_marginEnd="40dp"
                 android:src="@drawable/nav"
                 android:layout_marginStart="10dp"
                 android:id="@+id/nav" />

            <EditText
                 android:layout_height="wrap_content"
                 android:layout_width="200dp"
                 android:layout_marginEnd="10dp"
                 android:id="@+id/tulis" />

            <ImageView
                 android:layout_height="30dp"
                 android:layout_width="30dp"
                 android:src="@drawable/cari_file"
                 android:id="@+id/cari" />

        </LinearLayout>

        <LinearLayout
             android:layout_height="5dp"
             android:layout_width="match_parent"
             android:visibility="gone"
             android:paddingEnd="10dp"
             android:background="@color/ungu"
             android:layout_margin="5dp"
             android:paddingStart="10dp"
             android:id="@+id/proses">

            <LinearLayout
                 android:layout_height="match_parent"
                 android:layout_width="wrap_content"
                 android:background="@color/biru"
                 android:id="@+id/proses_berjalan">

            </LinearLayout>

        </LinearLayout>

        <android.webkit.WebView
             android:layout_height="match_parent"
             android:layout_width="match_parent"
             android:layout_margin="10dp"
             android:id="@+id/web">

        </android.webkit.WebView>

    </LinearLayout>

    <LinearLayout
         android:layout_height="match_parent"
         android:layout_width="300dp"
         android:background="@color/biru"
         android:orientation="vertical"
         android:layout_gravity="start">

        <FrameLayout
             android:layout_height="40dp"
             android:layout_width="match_parent">

            <TextView
                 android:layout_height="30dp"
                 android:layout_width="30dp"
                 android:background="#ff0000"
                 android:gravity="center"
                 android:textColor="@color/tulisan"
                 android:layout_marginStart="10dp"
                 android:layout_gravity="center_vertical"
                 android:text="X"
                 android:id="@+id/keluar" />

            <ImageView
                 android:layout_height="30dp"
                 android:layout_width="30dp"
                 android:layout_marginEnd="10dp"
                 android:src="@drawable/tutup"
                 android:id="@+id/tutup"
                 android:layout_gravity="end|center_vertical" />

            <ImageView
                 android:layout_height="30dp"
                 android:layout_width="30dp"
                 android:src="@drawable/google"
                 android:layout_marginStart="80dp"
                 android:id="@+id/google"
                 android:layout_gravity="center_vertical" />

            <ImageView
                 android:layout_height="30dp"
                 android:layout_width="30dp"
                 android:src="@drawable/duck"
                 android:layout_marginStart="140dp"
                 android:id="@+id/duck"
                 android:layout_gravity="center_vertical" />

        </FrameLayout>

        <LinearLayout
             android:layout_height="match_parent"
             android:layout_width="match_parent"
             android:layout_margin="10dp"
             android:orientation="vertical">

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:background="@color/ungu"
                 android:padding="10dp"
                 android:layout_margin="15dp"
                 android:textColor="@color/tulisan"
                 android:textStyle="bold"
                 android:id="@+id/unduhan"
                 android:text="UNDUHAN" />

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:background="@color/ungu"
                 android:padding="10dp"
                 android:layout_margin="15dp"
                 android:textColor="@color/tulisan"
                 android:textStyle="bold"
                 android:id="@+id/penelusuran"
                 android:text="Riwayat" />

            <Switch
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:background="@color/ungu"
                 android:layout_margin="15dp"
                 android:padding="10dp"
                 android:textColor="@color/tulisan"
                 android:paddingStart="10dp"
                 android:textStyle="bold"
                 android:id="@+id/mode"
                 android:text="Situs Desktop" />

        </LinearLayout>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>